# ── Instagram Downloader — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Instagram Auth (optional but strongly recommended) ────────────────────────
# Without credentials, only public posts work and Instagram may rate-limit you.
INSTAGRAM_USERNAME=your_username_here
INSTAGRAM_PASSWORD=your_password_here

# ── Cookie file (alternative to username/password for yt-dlp) ─────────────────
# Export via: yt-dlp --cookies-from-browser chrome --cookies cookies.txt
# Then set the path here:
COOKIES_FILE=

# ── Download storage ──────────────────────────────────────────────────────────
# Absolute or relative path where media files are saved.
DOWNLOAD_DIR=./downloads

# ── File retention ────────────────────────────────────────────────────────────
# How long to keep downloaded files (seconds). 0 = keep forever.
FILE_TTL_SECONDS=3600

# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_CONCURRENT=5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# ALLOWED_ORIGINS=["http://localhost:3000","https://yourfrontend.com"]
